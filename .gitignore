# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# project docs (override ~/.gitignore_global which ignores README.md)
!README.md

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# storybook
/storybook-static

# design-sync (generated / transient / verification state)
.design-sync/sb-reference/
.design-sync/learnings/
.design-sync/.cache/
.design-sync/node_modules
.design-sync/*.log
.ds-sync/
ds-bundle/

# playwright
/test-results
/playwright-report
/blob-report
/playwright/.cache

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local libsql / turso databases
*.db
*.db-journal
*.db-wal
*.db-shm

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# design-sync build artifacts
.design-sync/sb-reference/
.design-sync/learnings/
.design-sync/.cache/
.design-sync/node_modules
.ds-sync/
ds-bundle/
.claude/worktrees/
